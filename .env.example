# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, never expose to the browser. Used by
# lib/supabase/admin.ts to read/write encrypted PMS tokens (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte key for encrypting PMS tokens at rest. Generate: openssl rand -base64 32
MEWS_TOKEN_ENCRYPTION_KEY=your-base64-32-byte-key

# MEWS Connector API origin (no path). Defaults to production
# https://api.mews.com; use https://api.mews-demo.com for the demo environment.
MEWS_API_URL=https://api.mews.com

# Shared secret for the scheduled sync cron (GET /api/sync). Generate:
# openssl rand -hex 32. Vercel Cron sends it automatically as
# `Authorization: Bearer ${CRON_SECRET}` when this env var is set.
CRON_SECRET=your-cron-secret

# Apaleo OAuth2 app (https://apaleo.dev). The redirect URI registered with
# Apaleo must match APALEO_REDIRECT_URI (or {origin}/connect/apaleo/callback).
APALEO_CLIENT_ID=your-apaleo-client-id
APALEO_CLIENT_SECRET=your-apaleo-client-secret
# Optional — defaults to {request-origin}/connect/apaleo/callback
APALEO_REDIRECT_URI=
# Optional — defaults to "offline_access reservations.read rateplans.read setup.read"
APALEO_SCOPES=

# Gmail OAuth2 app (Google Cloud Console → APIs & Services → Credentials).
# Enable the Gmail API and add the redirect URI below to the OAuth client.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Optional — defaults to {request-origin}/connect/gmail/callback
GOOGLE_REDIRECT_URI=

# Sentry error monitoring (optional). Leave unset to disable. Get the DSN from
# your Sentry project (Settings → Client Keys). Use the same value for both.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Anthropic (morning briefing, email assistant, hotel chat)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (outbound email / check-in chasing)
RESEND_API_KEY=re_...
# Verified sender for outbound email. Defaults to Resend's test sender.
RESEND_FROM=Fonda <briefings@yourdomain.com>
